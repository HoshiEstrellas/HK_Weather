.page {
  padding: 32rpx 28rpx 48rpx;
}

.header {
  padding: 20rpx 0 28rpx;
}

.eyebrow {
  display: block;
  color: #6b7885;
  font-size: 22rpx;
  letter-spacing: 0;
}

.title {
  display: block;
  margin-top: 8rpx;
  color: #101820;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.1;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  color: #5b6b7a;
  font-size: 26rpx;
}

.actions {
  display: flex;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.actions button {
  flex: 1;
  height: 76rpx;
  color: #fff;
  background: #101820;
  font-weight: 600;
}

.actions button:first-child {
  background: #0e766e;
}

.info {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 34rpx;
}

.info view {
  min-height: 128rpx;
  padding: 20rpx;
  background: #fff;
  border: 1rpx solid #e0e6ec;
  border-radius: 8rpx;
}

.label {
  display: block;
  color: #71808d;
  font-size: 24rpx;
}

.value {
  display: block;
  margin-top: 12rpx;
  color: #18212b;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.3;
  word-break: break-all;
}

.section-title {
  margin: 16rpx 0;
  color: #101820;
  font-size: 32rpx;
  font-weight: 700;
}

.history {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.history-row {
  padding: 20rpx;
  background: #fff;
  border: 1rpx solid #e0e6ec;
  border-radius: 8rpx;
}

.history-main,
.history-data {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.temp {
  color: #0e766e;
  font-size: 40rpx;
  font-weight: 700;
}

.time {
  color: #5b6b7a;
  font-size: 24rpx;
}

.history-data {
  margin-top: 16rpx;
  color: #283846;
  font-size: 26rpx;
}

.error {
  margin: 18rpx 0;
  padding: 18rpx;
  color: #a33a2a;
  background: #fff2ef;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.loading,
.empty {
  padding: 48rpx 0;
  color: #687787;
  text-align: center;
  font-size: 28rpx;
}
