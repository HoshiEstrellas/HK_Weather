<view class="page">
  <view class="error" wx:if="{{error}}">{{error}}</view>
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <block wx:if="{{!loading && lamppost}}">
    <view class="header">
      <text class="eyebrow">LAMPOST DETAIL</text>
      <text class="title mono">{{lamppost.lpNumber}}</text>
      <text class="subtitle">{{lamppost.typeName}} · 设备 {{lamppost.deviceLabel}}</text>
    </view>

    <view class="actions">
      <button bindtap="openMap">地图</button>
      <button bindtap="copyCoordinate">复制坐标</button>
    </view>

    <view class="info">
      <view>
        <text class="label">坐标</text>
        <text class="value mono">{{lamppost.coordinateText}}</text>
      </view>
      <view>
        <text class="label">灯柱类型</text>
        <text class="value">{{lamppost.lpType}}</text>
      </view>
      <view>
        <text class="label">设备</text>
        <text class="value">{{lamppost.deviceIds}}</text>
      </view>
      <view>
        <text class="label">位置更新时间</text>
        <text class="value">{{lamppost.updatedText}}</text>
      </view>
    </view>

    <view class="section-title">历史观测</view>
    <view class="history">
      <view class="history-row" wx:for="{{history}}" wx:key="id">
        <view class="history-main">
          <text class="temp">{{item.temperatureText}}</text>
          <text class="time">{{item.observedText}}</text>
        </view>
        <view class="history-data">
          <text>湿度 {{item.humidityText}}</text>
          <text>风速 {{item.windSpeedText}}</text>
          <text>风向 {{item.windDirectionText}}</text>
        </view>
      </view>
      <view class="empty" wx:if="{{history.length == 0}}">
        这个灯柱暂时没有历史记录。
      </view>
    </view>
  </block>
</view>
